\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Physical bounds via PRE inversion for the 1D Advection equation ($U_t + v U_x = 0$). For a fixed-time spatial slice, point-wise (red), Interval FFT (grey), and perturbation sampling (blue) are shown together. To keep bounds numerically reasonable, envelope widths are clipped using a robust signal-scale cap.}}{5}{figure.5}\protected@file@percent }
\newlabel{fig:advection}{{5}{5}{Physical bounds via PRE inversion for the 1D Advection equation ($U_t + v U_x = 0$). For a fixed-time spatial slice, point-wise (red), Interval FFT (grey), and perturbation sampling (blue) are shown together. To keep bounds numerically reasonable, envelope widths are clipped using a robust signal-scale cap}{figure.5}{}}
