\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Physical bounds via PRE inversion for the Simple Harmonic Oscillator ($m \ddot  {x} + k x = 0$). Interval FFT (grey) gives a wider guaranteed envelope, while perturbation sampling (blue) provides an empirical accepted-sample envelope between point-wise and set-propagation bounds.}}{3}{figure.1}\protected@file@percent }
\newlabel{fig:sho}{{1}{3}{Physical bounds via PRE inversion for the Simple Harmonic Oscillator ($m \ddot {x} + k x = 0$). Interval FFT (grey) gives a wider guaranteed envelope, while perturbation sampling (blue) provides an empirical accepted-sample envelope between point-wise and set-propagation bounds}{figure.1}{}}
