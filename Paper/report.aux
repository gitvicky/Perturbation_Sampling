\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Physical bounds via PRE inversion for the Damped Harmonic Oscillator ($m \ddot  {x} + c \dot  {x} + k x = 0$). Interval FFT captures boundary edge-effects and phase variation conservatively, while perturbation sampling provides an empirical intermediate envelope.}}{4}{figure.3}\protected@file@percent }
\newlabel{fig:dho}{{3}{4}{Physical bounds via PRE inversion for the Damped Harmonic Oscillator ($m \ddot {x} + c \dot {x} + k x = 0$). Interval FFT captures boundary edge-effects and phase variation conservatively, while perturbation sampling provides an empirical intermediate envelope}{figure.3}{}}
